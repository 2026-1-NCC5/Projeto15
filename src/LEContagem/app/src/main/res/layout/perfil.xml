<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fundo_login">

    <!-- FUNDO ESCURO -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <!-- CARD COM CONTEÚDO -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_branco"
            android:padding="26dp"
            android:elevation="7dp">

            <!-- TÍTULO (AGORA VISÍVEL E ELEGANTE) -->
            <TextView
                android:id="@+id/txtTitleProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textColor="#4CAF50"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <!-- SUBTÍTULO -->
            <TextView
                android:id="@+id/txtAltereDados"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Altere seus Dados"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="20dp"/>

            <!-- NOME -->
            <EditText
                android:id="@+id/edtNome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nome"
                android:textColor="#000000"
                android:textSize="18sp"
                android:padding="14dp"
                android:background="@drawable/edittext_background"
                android:layout_marginBottom="15dp" />

            <!-- EMAIL -->
            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:textColor="#000000"
                android:textSize="18sp"
                android:padding="14dp"
                android:background="@drawable/edittext_background"
                android:layout_marginBottom="15dp" />

            <!-- SENHA -->
            <EditText
                android:id="@+id/edtSenha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Senha"
                android:inputType="textPassword"
                android:textColor="#000000"
                android:textSize="18sp"
                android:padding="14dp"
                android:background="@drawable/edittext_background"
                android:layout_marginBottom="15dp" />

            <!-- CARGO -->
            <EditText
                android:id="@+id/edtCargo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cargo"
                android:textColor="#000000"
                android:textSize="18sp"
                android:padding="14dp"
                android:background="@drawable/edittext_background"
                android:layout_marginBottom="25dp" />

            <!-- BOTÃO SALVAR -->
            <Button
                android:id="@+id/btnSalvar"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="15dp"
                android:backgroundTint="#4CAF50"
                android:text="Salvar Alterações"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <!-- BOTÃO VOLTAR -->
            <Button
                android:id="@+id/btnVoltarHome"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Voltar para Home"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>