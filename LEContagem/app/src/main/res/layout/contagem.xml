<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fundo_login">

    <!-- FUNDO ESCURECIDO -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/txtContagemTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        android:text="Contagem em Tempo Real"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CARD PRINCIPAL -->
    <LinearLayout
        android:id="@+id/cardContagem"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="26dp"
        android:background="@drawable/card_branco"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="20dp"
        android:elevation="7dp"
        app:layout_constraintTop_toBottomOf="@id/txtContagemTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- SELEÇÃO DE EQUIPE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Equipe ativa:"
            android:textColor="#4CAF50"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Spinner
            android:id="@+id/spinnerEquipe"
            android:layout_width="327dp"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:padding="6dp" />

        <!-- STATUS DA SESSÃO -->
        <TextView
            android:id="@+id/txtStatusSessao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Aguardando início"
            android:textColor="#000000"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:textStyle="italic"/>

        <!-- SEPARADOR -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#DDDDDD"/>

        <!-- ÚLTIMA DETECÇÃO -->
        <TextView
            android:id="@+id/txtUltimaDeteccao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Última detecção: Nenhuma"
            android:textColor="#000000"
            android:textSize="18sp"
            android:layout_marginBottom="14dp"/>

        <!-- CONFIANÇA DA PREDIÇÃO -->
        <TextView
            android:id="@+id/txtConfianca"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confiança: --%"
            android:textColor="#000000"
            android:textSize="18sp"
            android:layout_marginBottom="20dp"/>

        <!-- CONTADORES TOTAIS -->
        <TextView
            android:id="@+id/txtTotais"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Totais:"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/txtArroz"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Arroz: 0"
            android:textColor="#000000"
            android:textSize="20sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txtFeijao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Feijão: 0"
            android:textColor="#000000"
            android:textSize="20sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txtOutros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Outros: 0"
            android:textColor="#000000"
            android:textSize="20sp"/>

        <!-- BOTÃO INICIAR / ENCERRAR -->
        <Button
            android:id="@+id/btnIniciarEncerrar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="26dp"
            android:text="Iniciar Sessão"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#4CAF50"
        />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>